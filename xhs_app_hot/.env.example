# xhs_app_hot 环境变量模板
# 复制本文件为 .env，填写真实值（从 mitmproxy 抓包结果中获取）
# .env 文件不得提交到 git！

# ── Phase A1 抓包后填写 ─────────────────────────────────────────
# App 热点 API 完整 URL（示例，实际值待 Phase A1 发现）
HOT_API_URL=

# ── Phase A2 验证时填写 ─────────────────────────────────────────
# 从 mitmproxy 抓包结果的 request_headers 中复制
XHS_APP_COOKIE=
XHS_AUTHORIZATION=
XHS_APP_UA=

# 签名参数（如有）— Phase A2 判断是否需要
XHS_X_S=
XHS_X_T=

# ── 采集配置 ────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
REQUEST_INTERVAL=2.0
